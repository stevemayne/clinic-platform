# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- Editors / IDEs ---
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# --- Terraform ---
