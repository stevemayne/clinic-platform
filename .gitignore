crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl
.terraformrc
terraform.rc

# --- Secrets / local env ---
.env
.env.*
*.pem
*.key

# --- Logs / temp ---
*.log
tmp/
